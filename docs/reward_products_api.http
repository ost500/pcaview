###
### 필터링 및 정렬
###

### 카테고리별 필터링은 쿼리 파라미터 사용
# GET /api/reward-products?category=실물금

### 정렬 순서:
# 1. priority (내림차순, 높을수록 상단)
# 2. created_at (내림차순, 최신순)

### 상품 노출 조건:
# - is_active = true
# - stock > 0

###
### 리워드 상품 구매 (use_reward)
###

### 12. Reward 구매 (기존 방식) - Sanctum 토큰 필요
POST {{baseUrl}}/api/ytplayer/use_reward
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "encrypted": "{{encrypted}}",
  "reward_id": 1
}

### 13. RewardProduct 구매 (신규 방식) - Sanctum 토큰 필요
POST {{baseUrl}}/api/ytplayer/use_reward
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "encrypted": "{{encrypted}}",
  "reward_product_id": 9
}

### 13-1. RewardProduct 구매 (휴대폰 번호 포함) - Sanctum 토큰 필요
POST {{baseUrl}}/api/ytplayer/use_reward
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "encrypted": "{{encrypted}}",
  "reward_product_id": 9,
  "phone": "01012345678"
}

###
### 구매 응답 예시
###

### Reward 구매 성공 응답
# {
#   "success": true,
#   "data": {
#     "id": 123,
#     "reward_id": 1,
#     "reward_name": "프리미엄 구독권 1개월",
#     "points_spent": "1000.500000000",
#     "status": "completed",
#     "balance": 8999.5,
#     "total_spent": 1000.5,
#     "created_at": "2026-03-09T12:00:00+00:00"
#   }
# }

### RewardProduct 구매 성공 응답
# {
#   "success": true,
#   "data": {
#     "id": 124,
#     "reward_product_id": 9,
#     "product_name": "순금 1돈 (3.75g)",
#     "points_spent": "86764.000000000",
#     "status": "completed",
#     "balance": 13236.0,
#     "total_spent": 86764.0,
#     "created_at": "2026-03-09T12:05:00+00:00"
#   }
# }

### 구매 실패 - 재고 부족
# {
#   "success": false,
#   "error": "Product is out of stock"
# }

### 구매 실패 - 포인트 부족
# {
#   "success": false,
#   "error": "Insufficient points"
# }

### 구매 실패 - 비활성 상품
# {
#   "success": false,
#   "error": "Product is not available"
# }

### 구매 실패 - 파라미터 누락
# {
#   "success": false,
#   "error": "Either reward_id or reward_product_id is required"
# }

###
### 리워드 사용 내역 조회 (reward_usages)
###

### 14. 사용 내역 조회 (Reward + RewardProduct 통합) - Sanctum 토큰 필요
GET {{baseUrl}}/api/ytplayer/reward/usages?encrypted={{encrypted}}
Authorization: Bearer {{bearerToken}}
Accept: application/json

### 15. 사용 내역 조회 (limit 지정) - Sanctum 토큰 필요
GET {{baseUrl}}/api/ytplayer/reward/usages?encrypted={{encrypted}}&limit=50
Authorization: Bearer {{bearerToken}}
Accept: application/json

###
